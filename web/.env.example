# Optional build-time knobs for the Veritas demo — all have safe defaults, so the demo runs with no
# .env at all. Copy to web/.env only to override. The contract id, registry root, network passphrase,
# and verification key are pinned in src/lib/fixtures.js + the generated veritas-client bindings.

# 'demo' (default) shows the SIMULATED provenance badges + the "try to forge it" tamper button.
# 'prod' hides them (reserved for a future customer console — the demo build should stay 'demo').
VITE_VERITAS_ENV=demo

# Bind each run to a REAL testnet settlement payment (1 = on by default; 0 = disable, use a nonce ref).
VITE_REAL_PAYMENT=1

# Optional pre-funded testnet account (secret seed, starts with S). Used ONLY if Friendbot funding
# fails, so a rate-limited faucet never forces the cached fallback — the run stays live.
# TESTNET ONLY. Never put a mainnet secret here; anything in a VITE_ var ships in the client bundle.
VITE_DEMO_FUND_SECRET=

# Endpoints (defaults are the public SDF testnet services).
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_RPC_URL_BACKUP=
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
